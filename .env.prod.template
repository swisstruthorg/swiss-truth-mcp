# ─── Swiss Truth MCP — Production Environment ───────────────────────────────
# Kopiere diese Datei nach .env und fülle alle Werte aus
# cp .env.prod.template .env

# Domain (ohne https://)
DOMAIN=swisstruth.org

# Neo4j
NEO4J_PASSWORD=AENDERN_sicheres_passwort_hier

# Swiss Truth API Key (für /n8n/submit und andere geschützte Endpoints)
SWISS_TRUTH_API_KEY=AENDERN_langer_zufaelliger_key

# Anthropic (für zukünftige LLM-Features, kann leer bleiben)
ANTHROPIC_API_KEY=

# n8n Webhook (nach n8n-Migration hierher aktualisieren)
N8N_WEBHOOK_URL=https://n8n.swisstruth.org/webhook/fact-check

# n8n Encryption Key (einmal setzen, nie ändern — sonst Datenverlust!)
N8N_ENCRYPTION_KEY=AENDERN_32_zeichen_zufaelliger_key
